{
  "expo": {
    "name": "JSDIECAST.ID",
    "slug": "js-diecast-app",
    "version": "1.0.1",
    "web": {
      "favicon": "./assets/images/jsdiecast.jpg",
      "bundler": "metro"
    },
    "experiments": {
      "tsconfigPaths": true
    },
    "plugins": [
      "expo-secure-store"
    ],
    "orientation": "portrait",
    "icon": "./assets/images/jsdiecast.jpg",
    "userInterfaceStyle": "light",
    "backgroundColor": "#FFFFFF",
    "splash": {
      "image": "./assets/images/jsdiecast.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#EF4444"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "splash": {
        "image": "./assets/images/jsdiecast.jpg",
        "resizeMode": "contain",
        "backgroundColor": "#EF4444"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/jsdiecast.jpg",
        "backgroundColor": "#FFFFFF"
      },
      "splash": {
        "image": "./assets/images/jsdiecast.jpg",
        "resizeMode": "contain",
        "backgroundColor": "#EF4444"
      },
      "package": "com.nikohoc.jsdiecastapp"
    },
    "extra": {
      "eas": {
        "projectId": "4c32c509-c6a9-4932-9890-c937867986c4"
      }
    }
  }
}
